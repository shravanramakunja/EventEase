# ==============================
# EventEase — Environment Config
# ==============================
# Copy this file to .env and fill in your values
#
#   cp .env.example .env
#
# ==============================

# 🍃 MongoDB Atlas connection string
# Get this from MongoDB Atlas -> Connect -> Connect your application
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/eventease?retryWrites=true&w=majority

# 📧 Resend API Key (for sending emails)
# Sign up at https://resend.com -> API Keys -> Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxx

# 🔐 Admin login credentials (for /admin panel)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password

# 🔑 Session encryption secret (min 32 chars, use a random string)
SESSION_SECRET=your-random-64-char-hex-string

# 🚀 Port (Render sets automatically, this is just a local fallback)
PORT=8080

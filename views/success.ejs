<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Registration Successful – EventEase</title>
  <link rel="stylesheet" href="/css/fonts.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f0f0f] text-white font-exo min-h-screen flex items-center justify-center p-4">

  <div class="w-full max-w-md mx-auto bg-[#1b1b1b] border border-gray-700 p-6 sm:p-8 rounded-2xl shadow-lg text-center">

    <h2 class="text-2xl sm:text-3xl font-extrabold mb-6 text-yellow-400">
      Registration Successful 
    </h2>

    <div class="space-y-2 text-gray-300 text-base sm:text-lg">
      <p><span class="font-semibold text-yellow-400">Name:</span> <%= name %></p>
      <p><span class="font-semibold text-yellow-400">USN:</span> <%= usn %></p>
      <p><span class="font-semibold text-yellow-400">Department:</span> <%= department %></p>
      <p><span class="font-semibold text-yellow-400">Seat:</span> <%= seat %></p>
      <p><span class="font-semibold text-yellow-400">Parents:</span> <%= parents %></p>
    </div>

    <div class="mt-6 bg-yellow-400/20 border border-yellow-500 rounded-lg p-4 text-yellow-300 font-semibold text-sm sm:text-base">
      Your registration is <span class="text-yellow-400">pending admin approval</span>.<br>
      You will receive your QR code via email once approved.<br>
      <span class="text-yellow-400 text-base sm:text-xl font-bold break-words"><%= email %></span>
    </div>

    <a href="/" 
      class="mt-6 sm:mt-8 inline-block bg-yellow-400 text-black font-semibold px-6 py-2 rounded-lg hover:bg-yellow-300 transition">
      Register Another
    </a>

  </div>

</body>
</html>

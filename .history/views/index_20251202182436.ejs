<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>EventEase</title>
  <link rel="icon" type="image/png" href="/uploads/eventease-logo.png">
  <link rel="stylesheet" href="/css/fonts.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      background-image: 
        linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
      background-size: 50px 50px;
      background-position: center center;
    }

    @keyframes scroll {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }

    .animate-scroll {
      animation: scroll 20s linear infinite;
    }

    .animate-scroll:hover {
      animation-play-state: paused;
    }
  </style>
</head>

<body class="bg-[#0f0f0f] text-white font-exo">

  <!-- NAVBAR -->
  <nav class="w-full bg-[#0f0f0f] border-b border-gray-800 fixed top-0 left-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">

      <!-- LOGO IMAGE -->
      <a href="/" class="flex items-center gap-3">
        <img src="/uploads/eventease-logo.png" 
             alt="EventEase Logo" 
             class="h-20 w-auto object-contain">
      </a>

      <!-- DESKTOP MENU -->
      <div class="hidden md:flex items-center gap-6">

        <a href="/register" 
          class="bg-yellow-400 text-black px-5 py-2 rounded-lg font-semibold hover:bg-yellow-300 transition">
          Register Now
        </a>

        <a href="/admin"
          class="border border-gray-500 text-gray-200 px-5 py-2 rounded-lg font-semibold hover:bg-gray-800 transition">
          Admin Login
        </a>

      </div>

      <!-- MOBILE MENU BUTTON -->
      <button id="menuBtn" class="md:hidden text-yellow-400 text-3xl">
        ☰
      </button>

    </div>

    <!-- MOBILE MENU DROPDOWN -->
    <div id="mobileMenu" class="hidden bg-[#151515] border-t border-gray-700 md:hidden px-4 py-4 space-y-4">

      <a href="/register"
        class="block bg-yellow-400 text-black text-center px-5 py-2 rounded-lg font-semibold hover:bg-yellow-300 transition">
        Register Now
      </a>

      <a href="/admin"
        class="block border border-gray-500 text-gray-200 text-center px-5 py-2 rounded-lg font-semibold hover:bg-gray-800 transition">
        Admin Login
      </a>

    </div>
  </nav>

  <!-- SPACER (prevents hero from being hidden behind navbar) -->
  <div class="h-20"></div>

  <!-- HERO SECTION -->
  <section class="max-w-6xl mx-auto pt-6 sm:pt-10 pb-12 sm:pb-20 md:pb-24 text-center px-4">
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold bg-gradient-to-t from-yellow-600 via-yellow-400 to-yellow-200 bg-clip-text text-transparent leading-tight">
      EventEase
    </h1>

    <p class="mt-4 sm:mt-6 text-base sm:text-lg text-gray-300 max-w-2xl mx-auto px-2">
      A seamless event registration & check-in platform designed to simplify attendance,
      automate workflows, and enhance the entire event experience.
    </p>
  </section>

  <!-- SCROLLING TECH STACK SECTION -->
  <section class="py-8 sm:py-12 overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 mb-6 sm:mb-8">
      <h3 class="text-lg sm:text-xl md:text-2xl font-semibold text-center text-gray-300">
        Built with modern technology stack
      </h3>
    </div>
    
    <!-- Scrolling Container -->
    <div class="relative flex w-full">
      <div class="flex gap-8 animate-scroll">
        <!-- First Set -->
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">Node.js</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">Express</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">MongoDB</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">EJS</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">Tailwind CSS</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">QR Code</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">Nodemailer</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">JavaScript</span>
        </div>
        
        <!-- Duplicate Set for seamless loop -->
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">Node.js</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">Express</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">MongoDB</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">EJS</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">Tailwind CSS</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">QR Code</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">Nodemailer</span>
        </div>
        <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl px-8 py-4 whitespace-nowrap">
          <span class="text-white text-lg font-semibold">JavaScript</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS SECTION -->
  <section class="max-w-5xl mx-auto py-12 sm:py-16 md:pb-20 px-4">
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-4 sm:mb-6 md:mb-8">
      How It <span class="text-yellow-400">Works</span>
    </h2>
    <p class="text-center text-gray-400 text-sm sm:text-base mb-8 sm:mb-10 md:mb-12 max-w-2xl mx-auto px-2">
      Simple, fast, and efficient event management in just a few steps
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8">
      
      <!-- Step 1 -->
      <div class="text-center">
        <div class="bg-yellow-400 text-black w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
          1
        </div>
        <h3 class="text-lg font-semibold mb-2 text-yellow-400">Register</h3>
        <p class="text-gray-400 text-sm">Fill in your details and submit the registration form</p>
      </div>

      <!-- Step 2 -->
      <div class="text-center">
        <div class="bg-yellow-400 text-black w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
          2
        </div>
        <h3 class="text-lg font-semibold mb-2 text-yellow-400">Get QR Code</h3>
        <p class="text-gray-400 text-sm">Receive your seat number and QR code via email instantly</p>
      </div>

      <!-- Step 3 -->
      <div class="text-center">
        <div class="bg-yellow-400 text-black w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
          3
        </div>
        <h3 class="text-lg font-semibold mb-2 text-yellow-400">Scan at Event</h3>
        <p class="text-gray-400 text-sm">Show your QR code at the entrance for quick check-in</p>
      </div>

      <!-- Step 4 -->
      <div class="text-center">
        <div class="bg-yellow-400 text-black w-16 h-16 rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
          4
        </div>
        <h3 class="text-lg font-semibold mb-2 text-yellow-400">Enjoy Event</h3>
        <p class="text-gray-400 text-sm">Find your seat and enjoy a seamless event experience</p>
      </div>

    </div>
  </section>

  <!-- FEATURES SECTION -->
  <section class="max-w-6xl mx-auto py-12 sm:py-16 md:pb-20 px-4">
    <h2 class="text-2xl sm:text-3xl font-bold text-center mb-8 sm:mb-10 md:mb-12">
      Why Choose <span class="text-yellow-400">EventEase?</span>
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">

      <!-- Feature Card -->
      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-5 sm:p-6 hover:scale-105 transition">
        <h3 class="text-lg sm:text-xl font-semibold mb-2 text-yellow-400">Smart QR Check-In</h3>
        <p class="text-gray-300 text-sm sm:text-base">Instant verification using QR scanning with auto check-in updates.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-5 sm:p-6 hover:scale-105 transition">
        <h3 class="text-lg sm:text-xl font-semibold mb-2 text-yellow-400">Manual Check-In</h3>
        <p class="text-gray-300 text-sm sm:text-base">Fallback method using seat number and email/name if QR fails.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-5 sm:p-6 hover:scale-105 transition">
        <h3 class="text-lg sm:text-xl font-semibold mb-2 text-yellow-400">Admin Dashboard</h3>
        <p class="text-gray-300 text-sm sm:text-base">Live data of all attendees with check-in status and controls.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-5 sm:p-6 hover:scale-105 transition">
        <h3 class="text-lg sm:text-xl font-semibold mb-2 text-yellow-400">Auto Seat Assignment</h3>
        <p class="text-gray-300 text-sm sm:text-base">Seats are auto-generated and sent directly via email with QR.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-5 sm:p-6 hover:scale-105 transition">
        <h3 class="text-lg sm:text-xl font-semibold mb-2 text-yellow-400">Email With QR Code</h3>
        <p class="text-gray-300 text-sm sm:text-base">Users receive seat, department, parents count & QR instantly.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-5 sm:p-6 hover:scale-105 transition">
        <h3 class="text-lg sm:text-xl font-semibold mb-2 text-yellow-400">Excel & CSV Export</h3>
        <p class="text-gray-300 text-sm sm:text-base">One-click export for admin records and event documentation.</p>
      </div>

    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-black py-6 mt-8 sm:mt-12">
    <p class="text-center text-gray-400 text-xs sm:text-sm px-4">
      © <%= new Date().getFullYear() %> EventEase • All Rights Reserved
    </p>
  </footer>

  <!-- MOBILE MENU JS -->
  <script>
    const btn = document.getElementById("menuBtn");
    const menu = document.getElementById("mobileMenu");

    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
  </script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register • EventEase</title>
  <link rel="stylesheet" href="/css/fonts.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f0f0f] text-white min-h-screen flex items-center justify-center px-4 font-exo">

  <div class="bg-[#1a1a1a] border border-gray-700 p-6 sm:p-8 md:p-10 rounded-2xl shadow-xl max-w-xl w-full">

    <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-center mb-3">
      Register for <span class="text-yellow-400">EventEase</span>
    </h1>

    <p class="text-center text-gray-400 text-sm sm:text-base mb-6 sm:mb-8">
      Enter your details to receive your seat number and QR code.
    </p>

    <form action="/register" method="POST" class="space-y-4 sm:space-y-5">

      <!-- NAME -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium text-sm sm:text-base">Name</label>
        <input 
          type="text" 
          name="name" 
          required
          class="w-full p-2.5 sm:p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white text-sm sm:text-base focus:border-yellow-400 focus:outline-none">
      </div>

      <!-- USN -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium text-sm sm:text-base">USN</label>
        <input 
          type="text" 
          name="usn"
          required
          class="w-full p-2.5 sm:p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white text-sm sm:text-base focus:border-yellow-400 focus:outline-none">
      </div>

      <!-- EMAIL -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium text-sm sm:text-base">Email</label>
        <input 
          type="email" 
          name="email"
          required
          class="w-full p-2.5 sm:p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white text-sm sm:text-base focus:border-yellow-400 focus:outline-none">
      </div>

      <!-- DEPARTMENT DROPDOWN (MATCHES CONSTANTS.JS) -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium text-sm sm:text-base">Department</label>
        <select 
          name="department"
          required
          class="w-full p-2.5 sm:p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white text-sm sm:text-base focus:border-yellow-400 focus:outline-none">

          <option value="" disabled selected>Select Department</option>

          <option value="Aeronautical Engineering (AE)">Aeronautical Engineering (AE)</option>
          <option value="Civil Engineering (CE)">Civil Engineering (CE)</option>

          <option value="Aerospace Engineering (ASE)">Aerospace Engineering (ASE)</option>
          <option value="Chemical Engineering (CHE)">Chemical Engineering (CHE)</option>

          <option value="Electronics and Communication Engineering (ECE)">Electronics and Communication Engineering (ECE)</option>
          <option value="Industrial IOT (IIoT)">Industrial IOT (IIoT)</option>

          <option value="Computer Science and Engineering and Data Science (CD)">Computer Science and Engineering and Data Science (CD)</option>
          <option value="Artificial Intelligence and Machine Learning (AI & ML)">Artificial Intelligence and Machine Learning (AI & ML)</option>
          <option value="Computer Science and Design (CG)">Computer Science and Design (CG)</option>

          <option value="Computer Science and Engineering (CSE)">Computer Science and Engineering (CSE)</option>
          <option value="Information Science and Engineering (ISE)">Information Science and Engineering (ISE)</option>

          <option value="Mechanical Engineering (ME)">Mechanical Engineering (ME)</option>

        </select>
      </div>

      <!-- PARENTS DROPDOWN -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium text-sm sm:text-base">Parents Attending</label>
        <select 
          name="parents"
          required
          class="w-full p-2.5 sm:p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white text-sm sm:text-base focus:border-yellow-400 focus:outline-none">

          <option value="" disabled selected>Select Parent Count</option>

          <option value="0">No Parents</option>
          <option value="1">1 Parent</option>
          <option value="2">2 Parents</option>

        </select>
      </div>

      <!-- SUBMIT BUTTON -->
      <button
        class="w-full bg-yellow-400 text-black font-bold py-2.5 sm:py-3 rounded-lg hover:bg-yellow-300 transition text-sm sm:text-base">
        Submit Registration
      </button>

    </form>

    <!-- BACK TO HOME -->
    <div class="text-center mt-5 sm:mt-6">
      <a href="/" class="text-gray-400 hover:text-yellow-400 transition text-sm sm:text-base">
        ← Back to Home
      </a>
    </div>

  </div>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QR Check-in – EventEase</title>
  <link rel="stylesheet" href="/css/fonts.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/html5-qrcode"></script>

  <style>
    /* EVENTEASE YELLOW SCANNER BORDER */
    #reader__scan_region {
      border: 4px solid #facc15;  /* yellow-400 */
      border-radius: 14px;
      box-shadow: 0 0 25px rgba(250, 204, 21, 0.6);
    }

    #reader video {
      border-radius: 14px;
    }
  </style>
</head>

<body class="bg-[#0f0f0f] text-white font-exo min-h-screen flex items-center justify-center p-4">

  <div class="w-full max-w-sm sm:max-w-md md:max-w-lg lg:max-w-2xl xl:max-w-4xl bg-[#1b1b1b] border border-gray-700 p-4 sm:p-6 md:p-8 rounded-2xl shadow-xl">

    <h1 class="text-2xl sm:text-3xl md:text-4xl font-extrabold text-center mb-4 sm:mb-6 text-yellow-400">
      QR Check-In
    </h1>

    <div id="reader" class="w-full"></div>

    <div id="result" class="mt-4 sm:mt-6 text-center text-lg sm:text-xl md:text-2xl font-semibold"></div>

  </div>

  <script>
    function onScanSuccess(decodedText) {
      let data;

      try {
        data = JSON.parse(decodedText);   // expecting: { uniqueId: "..." }
      } catch {
        document.getElementById("result").innerHTML =
          `<span class="text-red-500">❌ Invalid QR Code</span>`;
        return;
      }

      fetch("/checkin/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ uniqueId: data.uniqueId })
      })
      .then(res => res.json())
      .then(res => {

        if (res.success) {
          document.getElementById("result").innerHTML =
            `<span class="text-green-400">✔ Checked in: ${res.data.Name}</span>`;

          setTimeout(() => window.location.href = res.redirect, 700);
        } else {
          document.getElementById("result").innerHTML =
            `<span class="text-red-500">❌ ${res.message}</span>`;
        }
      })
      .catch(() => {
        document.getElementById("result").innerHTML =
          `<span class="text-red-500">❌ Server Error</span>`;
      });
    }

    // Calculate QR box size based on screen width
    const screenWidth = window.innerWidth;
    let qrboxSize;
    
    if (screenWidth < 640) {
      // Mobile: 80% of screen width, max 300px
      qrboxSize = Math.min(screenWidth * 0.8, 300);
    } else if (screenWidth < 768) {
      // Small tablets: 400px
      qrboxSize = 400;
    } else if (screenWidth < 1024) {
      // Medium tablets: 500px
      qrboxSize = 500;
    } else {
      // Desktop: 600px
      qrboxSize = 600;
    }

    const scanner = new Html5QrcodeScanner("reader", {
      fps: 10,
      qrbox: { width: qrboxSize, height: qrboxSize },
      aspectRatio: 1,
      disableFlip: false,
      rememberLastUsedCamera: true
    });

    scanner.render(onScanSuccess);
  </script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login – EventEase</title>
  <link rel="stylesheet" href="/css/fonts.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f0f0f] text-white font-exo min-h-screen flex items-center justify-center p-4">

  <div class="w-full max-w-sm mx-auto bg-[#1b1b1b] border border-gray-700 p-6 sm:p-8 rounded-2xl shadow-xl">

    <h1 class="text-2xl sm:text-3xl font-extrabold text-center mb-6 text-yellow-400">
      Admin Login
    </h1>

    <% if (error) { %>
      <p class="bg-red-500/20 border border-red-500 text-red-300 p-2 rounded text-center mb-4">
        <%= error %>
      </p>
    <% } %>

    <form action="/admin/login" method="POST" class="space-y-5">

      <div>
        <label class="block font-semibold text-gray-300 mb-1">Email</label>
        <input
          type="email"
          name="email"
          required
          class="w-full bg-[#111] border border-gray-700 text-white p-3 rounded-lg focus:border-yellow-400 outline-none"
        >
      </div>

      <div>
        <label class="block font-semibold text-gray-300 mb-1">Password</label>
        <input
          type="password"
          name="password"
          required
          class="w-full bg-[#111] border border-gray-700 text-white p-3 rounded-lg focus:border-yellow-400 outline-none"
        >
      </div>

      <button
        class="w-full bg-yellow-400 text-black font-semibold py-3 rounded-lg hover:bg-yellow-300 transition">
        Login
      </button>
    </form>

  </div>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>QR Check-in</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/html5-qrcode"></script>

  <style>
    /* PAYTM STYLE SCANNER BORDER */
    #reader__scan_region {
      border: 4px solid #00A8F3; 
      border-radius: 12px;
      box-shadow: 0 0 25px rgba(0, 168, 243, 0.7);
    }

    #reader video {
      border-radius: 12px;
    }
  </style>
</head>

<body class="bg-gray-100">

  <div class="max-w-xl mx-auto mt-10 bg-white p-6 rounded-xl shadow">

    <h1 class="text-2xl font-bold text-center mb-4">QR Check-in</h1>

    <div id="reader" class="w-full"></div>

    <div id="result" class="mt-4 text-center text-lg font-semibold"></div>

  </div>

  <script>
    function onScanSuccess(decodedText) {
      let data;

      try {
        data = JSON.parse(decodedText);   // expecting: { uniqueId: "..." }
      } catch {
        document.getElementById("result").innerHTML =
          `<span class="text-red-600">❌ Invalid QR Code</span>`;
        return;
      }

      fetch("/checkin/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ uniqueId: data.uniqueId })
      })
      .then(res => res.json())
      .then(res => {

        if (res.success) {
          document.getElementById("result").innerHTML =
            `<span class="text-green-600">✔ Checked in: ${res.data.Name}</span>`;

          setTimeout(() => window.location.href = res.redirect, 700);
        } else {
          document.getElementById("result").innerHTML =
            `<span class="text-red-600">❌ ${res.message}</span>`;
        }
      })
      .catch(() => {
        document.getElementById("result").innerHTML =
          `<span class="text-red-600">❌ Server Error</span>`;
      });
    }

    // PAYTM STYLE SCANNER CONFIG
    const scanner = new Html5QrcodeScanner("reader", {
      fps: 10,
      qrbox: { width: 320, height: 320 },  // bigger scan box
      aspectRatio: 1,
      disableFlip: false,
      rememberLastUsedCamera: true
    });

    scanner.render(onScanSuccess);
  </script>

</body>
</html>

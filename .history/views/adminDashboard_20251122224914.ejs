<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

  <div class="max-w-6xl mx-auto mt-10">

    <h1 class="text-3xl font-bold text-center mb-6">Admin Dashboard</h1>

    <div class="flex justify-between mb-4">
      <a href="/checkin" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">
        Open Check-in Scanner
      </a>

      <a href="/admin/export" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
        Export CSV
      </a>
    </div>

    <div class="bg-white shadow rounded-lg overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-200">
          <tr>
            <th class="p-2">Name</th>
            <th class="p-2">USN</th>
            <th class="p-2">Email</th>
            <th class="p-2">Food</th>
            <th class="p-2">Seat</th>
            <th class="p-2">Checked In</th>
          </tr>
        </thead>
        <tbody>
          <% data.forEach(user => { %>
            <tr class="<%= user.CheckedIn === 'Yes' ? 'bg-green-100' : '' %>">
              <td class="p-2"><%= user.Name %></td>
              <td class="p-2"><%= user.USN %></td>
              <td class="p-2"><%= user.Email %></td>
              <td class="p-2"><%= user.Food %></td>
              <td class="p-2"><%= user.Seat %></td>
              <td class="p-2 font-semibold">
                <%= user.CheckedIn === 'Yes' ? '✔️ Yes' : '❌ No' %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</body>
</html>

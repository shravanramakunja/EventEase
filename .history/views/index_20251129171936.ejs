<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>EventEase – Smart Event Check-In System</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f0f0f] text-white">

  <!-- NAVBAR -->
  <nav class="w-full bg-[#0f0f0f] border-b border-gray-800 fixed top-0 left-0 z-50">
    <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">

      <!-- LOGO IMAGE -->
      <a href="/" class="flex items-center gap-3">
        <img src="/uploads/eventease-logo.png" 
             alt="EventEase Logo" 
             class="h-40 w-auto object-contain">
      </a>

      <!-- DESKTOP MENU -->
      <div class="hidden md:flex items-center gap-6">

        <a href="/register" 
          class="bg-yellow-400 text-black px-5 py-2 rounded-lg font-semibold hover:bg-yellow-300 transition">
          Register Now
        </a>

        <a href="/admin"
          class="border border-gray-500 text-gray-200 px-5 py-2 rounded-lg font-semibold hover:bg-gray-800 transition">
          Admin Login
        </a>

      </div>

      <!-- MOBILE MENU BUTTON -->
      <button id="menuBtn" class="md:hidden text-yellow-400 text-3xl">
        ☰
      </button>

    </div>

    <!-- MOBILE MENU DROPDOWN -->
    <div id="mobileMenu" class="hidden bg-[#151515] border-t border-gray-700 md:hidden px-4 py-4 space-y-4">

      <a href="/register"
        class="block bg-yellow-400 text-black text-center px-5 py-2 rounded-lg font-semibold hover:bg-yellow-300 transition">
        Register Now
      </a>

      <a href="/admin"
        class="block border border-gray-500 text-gray-200 text-center px-5 py-2 rounded-lg font-semibold hover:bg-gray-800 transition">
        Admin Login
      </a>

    </div>
  </nav>

  <!-- SPACER (prevents hero from being hidden behind navbar) -->
  <div class="h-20"></div>

  <!-- HERO SECTION -->
  <section class="max-w-6xl mx-auto pt-10 pb-24 text-center px-4">
    <h1 class="text-5xl font-extrabold leading-tight">
      Welcome to <span class="text-yellow-400">EventEase</span>
    </h1>

    <p class="mt-6 text-lg text-gray-300 max-w-2xl mx-auto">
      A seamless event registration & check-in platform designed to simplify attendance,
      automate workflows, and enhance the entire event experience.
    </p>

    <div class="mt-10 flex justify-center gap-6">
      <a href="/register"
        class="bg-yellow-400 text-black font-semibold px-7 py-3 rounded-lg hover:bg-yellow-300 transition">
        Register Now
      </a>

      <a href="/admin"
        class="border border-gray-400 text-gray-200 font-semibold px-7 py-3 rounded-lg hover:bg-gray-800 transition">
        Admin Login
      </a>
    </div>
  </section>

  <!-- FEATURES SECTION -->
  <section class="max-w-6xl mx-auto pb-20 px-4">
    <h2 class="text-3xl font-bold text-center mb-12">
      Why Choose <span class="text-yellow-400">EventEase?</span>
    </h2>

    <div class="grid md:grid-cols-3 gap-8">

      <!-- Feature Card -->
      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-6 hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-2 text-yellow-400">Smart QR Check-In</h3>
        <p class="text-gray-300">Instant verification using QR scanning with auto check-in updates.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-6 hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-2 text-yellow-400">Manual Check-In</h3>
        <p class="text-gray-300">Fallback method using seat number and email/name if QR fails.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-6 hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-2 text-yellow-400">Admin Dashboard</h3>
        <p class="text-gray-300">Live data of all attendees with check-in status and controls.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-6 hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-2 text-yellow-400">Auto Seat Assignment</h3>
        <p class="text-gray-300">Seats are auto-generated and sent directly via email with QR.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-6 hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-2 text-yellow-400">Email With QR Code</h3>
        <p class="text-gray-300">Users receive seat, department, parents count & QR instantly.</p>
      </div>

      <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-6 hover:scale-105 transition">
        <h3 class="text-xl font-semibold mb-2 text-yellow-400">Excel & CSV Export</h3>
        <p class="text-gray-300">One-click export for admin records and event documentation.</p>
      </div>

    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-black py-6 mt-12">
    <p class="text-center text-gray-400 text-sm">
      © <%= new Date().getFullYear() %> EventEase • All Rights Reserved
    </p>
  </footer>

  <!-- MOBILE MENU JS -->
  <script>
    const btn = document.getElementById("menuBtn");
    const menu = document.getElementById("mobileMenu");

    btn.addEventListener("click", () => {
      menu.classList.toggle("hidden");
    });
  </script>

</body>
</html>

<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Success</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

<div class="max-w-md mx-auto mt-10 bg-white p-8 rounded shadow text-center">

  <h2 class="text-2xl font-bold mb-4">Registration Successful</h2>

  <p><strong>Name:</strong> <%= name %></p>
  <p><strong>USN:</strong> <%= usn %></p>
  <p><strong>Department:</strong> <%= department %></p>
  <p><strong>Seat:</strong> <%= seat %></p>
  <p><strong>Parents:</strong> <%= parents %></p>

  <img src="<%= qrDataUrl %>" class="mx-auto mt-4" />

  <a href="/" class="text-yellow-600 mt-6 inline-block">Register Another</a>

</div>

</body>
</html>

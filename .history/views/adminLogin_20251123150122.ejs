<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Login</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">

  <div class="max-w-sm mx-auto mt-20 bg-white p-8 shadow rounded-xl">

    <h1 class="text-2xl font-bold text-center mb-6">Admin Login</h1>

    <% if (error) { %>
      <p class="bg-red-200 text-red-800 p-2 rounded mb-4 text-center"><%= error %></p>
    <% } %>

    <form action="/admin/login" method="POST" class="space-y-4">
      <div>
        <label class="block font-semibold">Email</label>
        <input type="email" name="email" required class="w-full border rounded p-2">
      </div>

      <div>
        <label class="block font-semibold">Password</label>
        <input type="password" name="password" required class="w-full border rounded p-2">
      </div>

      <button class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700">
        Login
      </button>
    </form>

  </div>

</body>
</html>

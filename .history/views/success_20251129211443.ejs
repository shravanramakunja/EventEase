<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Registration Successful – EventEase</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Exo:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f0f0f] text-white font-exo">

  <div class="max-w-md mx-auto mt-16 bg-[#1b1b1b] border border-gray-700 p-8 rounded-2xl shadow-lg text-center">

    <h2 class="text-3xl font-extrabold mb-6 text-yellow-400">
      Registration Successful 
    </h2>

    <div class="space-y-2 text-gray-300 text-lg">
      <p><span class="font-semibold text-yellow-400">Name:</span> <%= name %></p>
      <p><span class="font-semibold text-yellow-400">USN:</span> <%= usn %></p>
      <p><span class="font-semibold text-yellow-400">Department:</span> <%= department %></p>
      <p><span class="font-semibold text-yellow-400">Seat:</span> <%= seat %></p>
      <p><span class="font-semibold text-yellow-400">Parents:</span> <%= parents %></p>
    </div>

    <div class="mt-6 bg-yellow-400/20 border border-yellow-500 rounded-lg p-4 text-yellow-300 font-semibold">
      Please check the confirmation email sent to<br>
      <span class="text-yellow-400 text-xl font-bold"><%= email %></span>
    </div>

    <a href="/" 
      class="mt-8 inline-block bg-yellow-400 text-black font-semibold px-6 py-2 rounded-lg hover:bg-yellow-300 transition">
      Register Another
    </a>

  </div>

</body>
</html>

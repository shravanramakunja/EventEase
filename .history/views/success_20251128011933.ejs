<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Registration Successful</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-xl shadow text-center">

    <h2 class="text-2xl font-bold mb-4 text-green-600">Registration Successful</h2>

    <p class="text-gray-800"><strong>Name:</strong> <%= name %></p>
    <p class="text-gray-800"><strong>USN:</strong> <%= usn %></p>
    <p class="text-gray-800"><strong>Department:</strong> <%= department %></p>
    <p class="text-gray-800"><strong>Seat:</strong> <%= seat %></p>
    <p class="text-gray-800"><strong>Parents:</strong> <%= parents %></p>

    <div class="mt-6 bg-yellow-100 p-3 rounded text-yellow-900 font-semibold">
      📩 Please check the email sent to<br>
      <span class="text-blue-700"><%= email %></span>
    </div>

    <a href="/" class="mt-6 inline-block text-yellow-600 hover:underline">Register Another</a>

  </div>

</body>
</html>

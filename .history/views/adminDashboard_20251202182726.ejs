<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard – EventEase</title>
  <link rel="stylesheet" href="/css/fonts.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f0f0f] text-white font-exo">

<!-- NAVBAR -->
<nav class="w-full bg-[#0f0f0f] border-b border-gray-800 p-4">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
    <h1 class="text-xl sm:text-2xl font-bold text-yellow-400">Admin Dashboard</h1>

    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 w-full sm:w-auto">
      <a href="/checkin" 
        class="bg-yellow-400 text-black font-semibold px-4 py-2 rounded-lg hover:bg-yellow-300 transition text-center">
        Check-In Scanner
      </a>

      <a href="/admin/export" 
        class="bg-blue-600 text-white font-semibold px-4 py-2 rounded-lg hover:bg-blue-500 transition text-center">
        Export CSV
      </a>
    </div>
  </div>
</nav>


<div class="max-w-6xl mx-auto mt-10 px-4">

  <!-- Manual Check-In -->
  <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-4 sm:p-6 mb-8">
    <h2 class="text-lg sm:text-xl font-semibold text-yellow-400 mb-4">Manual Check-In</h2>

    <form id="manualCheckinForm" class="space-y-3">

      <input 
        type="text" id="seat" name="seat" placeholder="Seat Number"
        class="bg-[#111] border border-gray-700 text-white p-3 w-full rounded-lg focus:border-yellow-400 outline-none"
      >

      <input 
        type="text" id="email" name="email" placeholder="Email or Name"
        class="bg-[#111] border border-gray-700 text-white p-3 w-full rounded-lg focus:border-yellow-400 outline-none"
      >

      <button type="submit"
        class="bg-yellow-400 hover:bg-yellow-300 text-black font-semibold px-4 py-2 rounded-lg transition">
        Confirm Check-In
      </button>
    </form>

    <p id="manualMessage" class="mt-3 font-medium"></p>
  </div>



  <!-- ADVANCED FILTERS -->
  <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl p-4 sm:p-5 mb-6">

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4">

      <!-- Search -->
      <input
        id="searchInput"
        type="text"
        placeholder="Search by anything..."
        class="bg-[#111] border border-gray-700 text-white p-3 rounded-lg focus:border-yellow-400 outline-none"
      />

      <!-- Department Dropdown (UPDATED from constants.js) -->
      <select id="deptFilter"
        class="bg-[#111] border border-gray-700 text-white p-3 rounded-lg focus:border-yellow-400 outline-none">
        <option value="">All Departments</option>
        <% departments.forEach(dep => { %>
          <option value="<%= dep %>"><%= dep %></option>
        <% }) %>
      </select>

      <!-- Sort -->
      <select id="sortBy"
        class="bg-[#111] border border-gray-700 text-white p-3 rounded-lg focus:border-yellow-400 outline-none">
        <option value="">Sort By</option>
        <option value="name">Name (A–Z)</option>
        <option value="usn">USN</option>
        <option value="seat">Seat</option>
      </select>

    </div>

    <!-- Checked-in Toggle -->
    <div class="mt-4 flex items-center gap-2">
      <input type="checkbox" id="checkedToggle" class="w-5 h-5">
      <label for="checkedToggle" class="text-yellow-400 font-medium">Show only checked-in</label>
    </div>

  </div>



  <!-- USERS TABLE -->
  <div class="bg-[#1b1b1b] border border-gray-700 rounded-xl overflow-x-auto">

    <table id="dataTable" class="w-full text-left min-w-[800px]">
      <thead class="bg-[#111] border-b border-gray-700">
        <tr class="text-yellow-400">
          <th class="p-2 sm:p-3 text-xs sm:text-sm">Name</th>
          <th class="p-2 sm:p-3 text-xs sm:text-sm">USN</th>
          <th class="p-2 sm:p-3 text-xs sm:text-sm">Email</th>
          <th class="p-2 sm:p-3 text-xs sm:text-sm">Department</th>
          <th class="p-2 sm:p-3 text-xs sm:text-sm">Seat</th>
          <th class="p-2 sm:p-3 text-xs sm:text-sm">Parents</th>
          <th class="p-2 sm:p-3 text-xs sm:text-sm">Checked In</th>
          <th class="p-2 sm:p-3 text-xs sm:text-sm">ID</th>
          <th class="p-2 sm:p-3 text-xs sm:text-sm">Actions</th>
        </tr>
      </thead>

      <tbody>
        <% data.forEach(u => { 
            const idVal = u.uniqueId || u.UniqueID || u.UniqueId || u.uniqueID || '';
        %>
        <tr class="user-row <%= u.CheckedIn === 'Yes' ? 'checked bg-green-900/30' : 'notchecked bg-[#0f0f0f]' %> border-b border-gray-800"
            data-name="<%= u.Name.toLowerCase() %>"
            data-usn="<%= u.USN.toLowerCase() %>"
            data-email="<%= u.Email.toLowerCase() %>"
            data-dept="<%= u.Department.toLowerCase() %>"
            data-seat="<%= u.Seat.toString().toLowerCase() %>"
            data-checked="<%= u.CheckedIn %>">

          <td class="p-2 sm:p-3 text-xs sm:text-sm"><%= u.Name %></td>
          <td class="p-2 sm:p-3 text-xs sm:text-sm"><%= u.USN %></td>
          <td class="p-2 sm:p-3 text-xs sm:text-sm"><%= u.Email %></td>
          <td class="p-2 sm:p-3 text-xs sm:text-sm"><%= u.Department %></td>
          <td class="p-2 sm:p-3 text-xs sm:text-sm"><%= u.Seat %></td>
          <td class="p-2 sm:p-3 text-xs sm:text-sm"><%= u.Parents %></td>
          <td class="p-2 sm:p-3 text-xs sm:text-sm">
            <span class="<%= u.CheckedIn === 'Yes'
                ? 'text-green-400 font-semibold'
                : 'text-red-400 font-semibold' %>">
              <%= u.CheckedIn %>
            </span>
          </td>

          <td class="p-2 sm:p-3 font-mono text-gray-400 text-xs"><%= idVal %></td>

          <td class="p-2 sm:p-3">m:p-3">
            <% if (idVal && idVal.length > 0) { %>
              <a href="/admin/delete/<%= idVal %>"
                 class="bg-red-600 hover:bg-red-500 text-white px-2 sm:px-3 py-1 rounded-lg font-semibold transition text-xs sm:text-sm inline-block whitespace-nowrap">
                Delete
              </a>
            <% } else { %>
              <button disabled
                class="bg-gray-600 text-gray-300 px-2 sm:px-3 py-1 rounded-lg cursor-not-allowed text-xs sm:text-sm whitespace-nowrap">
                Delete
              </button>
            <% } %>
          </td>

        </tr>
        <% }) %>
      </tbody>
    </table>

  </div>

</div>


<script src="/js/manualCheckin.js"></script>

<!-- ⭐ ADVANCED FILTER SCRIPT -->
<script>
  const searchInput = document.getElementById("searchInput");
  const deptFilter = document.getElementById("deptFilter");
  const sortBy = document.getElementById("sortBy");
  const checkedToggle = document.getElementById("checkedToggle");
  const rows = [...document.querySelectorAll(".user-row")];

  function applyFilters() {
    const search = searchInput.value.toLowerCase();
    const dept = deptFilter.value.toLowerCase();
    const showChecked = checkedToggle.checked;

    rows.forEach(row => {
      const matchesSearch = row.innerText.toLowerCase().includes(search);
      const matchesDept = dept === "" || row.dataset.dept === dept;
      const matchesChecked = !showChecked || row.dataset.checked === "Yes";

      row.style.display = (matchesSearch && matchesDept && matchesChecked) ? "" : "none";
    });
  }

  searchInput.addEventListener("input", applyFilters);
  deptFilter.addEventListener("change", applyFilters);
  checkedToggle.addEventListener("change", applyFilters);


  // Sorting
  sortBy.addEventListener("change", function () {
    const tbody = document.querySelector("#dataTable tbody");
    const type = this.value;

    let sorted = [...rows];

    if (type === "name") {
      sorted.sort((a,b) => a.dataset.name.localeCompare(b.dataset.name));
    } 
    else if (type === "usn") {
      sorted.sort((a,b) => a.dataset.usn.localeCompare(b.dataset.usn));
    }
    else if (type === "seat") {
      sorted.sort((a,b) => Number(a.dataset.seat) - Number(b.dataset.seat));
    }

    sorted.forEach(r => tbody.appendChild(r));
  });
</script>


</body>
</html>

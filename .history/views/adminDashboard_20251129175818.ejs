<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="max-w-6xl mx-auto mt-10">

  <h1 class="text-3xl font-bold text-center mb-6">Admin Dashboard</h1>

  <div class="flex justify-between mb-4">
    <a href="/checkin" class="bg-green-600 text-white px-4 py-2 rounded">Check-In Scanner</a>
    <a href="/admin/export" class="bg-blue-600 text-white px-4 py-2 rounded">Export CSV</a>
  </div>

  <!-- Manual Check-In -->
  <div class="bg-white shadow p-5 rounded mb-6">
    <h2 class="text-xl font-semibold mb-3">Manual Check-In</h2>

    <form id="manualCheckinForm" class="space-y-3">
      <input type="text" id="seat" name="seat" placeholder="Seat Number"
        class="border p-2 w-full rounded">

      <input type="text" id="email" name="email" placeholder="Email or Name"
        class="border p-2 w-full rounded">

      <button type="submit"
        class="bg-yellow-500 hover:bg-yellow-600 text-black px-4 py-2 rounded font-semibold">
        Confirm Check-In
      </button>
    </form>

    <p id="manualMessage" class="mt-3 font-medium"></p>
  </div>


  <!-- USERS TABLE -->
  <div class="bg-white shadow rounded overflow-hidden">
    <table class="w-full">
      <thead class="bg-gray-200">
        <tr>
          <th class="p-2">Name</th>
          <th class="p-2">USN</th>
          <th class="p-2">Email</th>
          <th class="p-2">Department</th>
          <th class="p-2">Seat</th>
          <th class="p-2">Parents</th>
          <th class="p-2">Checked In</th>
          <th class="p-2">Actions</th>
        </tr>
      </thead>

      <tbody>
        <% data.forEach(u => { %>
        <tr class="<%= u.CheckedIn === 'Yes' ? 'bg-green-100' : '' %>">
          <td class="p-2"><%= u.Name %></td>
          <td class="p-2"><%= u.USN %></td>
          <td class="p-2"><%= u.Email %></td>
          <td class="p-2"><%= u.Department %></td>
          <td class="p-2"><%= u.Seat %></td>
          <td class="p-2"><%= u.Parents %></td>
          <td class="p-2"><%= u.CheckedIn %></td>
          <td class="p-2">

            <!-- FIXED DELETE LINK -->
            <a href="/admin/delete/<%= u.UniqueId %>"
              class="bg-red-600 text-white px-3 py-1 rounded">
              Delete
            </a>

          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

</div>

<script src="/js/manualCheckin.js"></script>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Register • EventEase</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-[#0f0f0f] text-white min-h-screen flex items-center justify-center px-4">

  <div class="bg-[#1a1a1a] border border-gray-700 p-10 rounded-2xl shadow-xl max-w-xl w-full">

    <h1 class="text-4xl font-extrabold text-center mb-3">
      Register for <span class="text-yellow-400">EventEase</span>
    </h1>

    <p class="text-center text-gray-400 mb-8">
      Enter your details to get your seat number and QR code.
    </p>

    <form action="/register" method="POST" class="space-y-5">

      <!-- NAME -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium">Name</label>
        <input 
          type="text" 
          name="name" 
          required
          class="w-full p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white focus:border-yellow-400 focus:outline-none">
      </div>

      <!-- USN -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium">USN</label>
        <input 
          type="text" 
          name="usn"
          required
          class="w-full p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white focus:border-yellow-400 focus:outline-none">
      </div>

      <!-- EMAIL -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium">Email</label>
        <input 
          type="email" 
          name="email"
          required
          class="w-full p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white focus:border-yellow-400 focus:outline-none">
      </div>

      <!-- DEPARTMENT DROPDOWN -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium">Department</label>
        <select 
          name="department"
          required
          class="w-full p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white focus:border-yellow-400 focus:outline-none">

          <option value="" disabled selected>Select Department</option>

          <option value="CSE">CSE – Computer Science Engineering</option>
          <option value="ISE">ISE – Information Science Engineering</option>
          <option value="ECE">ECE – Electronics & Communication</option>
          <option value="EEE">EEE – Electrical & Electronics</option>
          <option value="ME">ME – Mechanical Engineering</option>
          <option value="CE">CE – Civil Engineering</option>
          <option value="AI & ML">AI & ML – Artificial Intelligence & Machine Learning</option>
          <option value="AI & DS">AI & DS – Artificial Intelligence & Data Science</option>
          <option value="RA">Robotics & Automation</option>
          <option value="BCA">BCA / Computer Applications</option>

        </select>
      </div>

      <!-- PARENTS DROPDOWN -->
      <div>
        <label class="block mb-1 text-gray-300 font-medium">Parents Attending</label>
        <select 
          name="parents"
          required
          class="w-full p-3 rounded-lg bg-[#0f0f0f] border border-gray-600 text-white focus:border-yellow-400 focus:outline-none">

          <option value="" disabled selected>Select Parent Count</option>

          <option value="0">No Parents</option>
          <option value="1">1 Parent</option>
          <option value="2">2 Parents</option>

        </select>
      </div>

      <!-- SUBMIT BUTTON -->
      <button
        class="w-full bg-yellow-400 text-black font-bold py-3 rounded-lg hover:bg-yellow-300 transition">
        Submit Registration
      </button>

    </form>

    <!-- BACK TO HOME -->
    <div class="text-center mt-6">
      <a href="/" class="text-gray-400 hover:text-yellow-400 transition">
        ← Back to Home
      </a>
    </div>

  </div>

</body>
</html>
